#!/usr/bin/env python3
"""dmf-scan — CLI for the shared public-safety scan library (R1 spec §6).

Thin wrapper: the implementation lives in bin/lib/dmf_scan.py so tooling
(the §9.1 parity checker, tests) can import it. See that module's docstring
for contexts, surfaces, and the §5.5 failure classes.
"""
import os
import sys

sys.path.insert(0, os.path.join(os.path.dirname(os.path.abspath(__file__)), "lib"))
from dmf_scan import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
