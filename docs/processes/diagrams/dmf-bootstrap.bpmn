<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_DMFBootstrap"
  targetNamespace="http://dmfdeploy.dev/processes"
  exporter="Camunda Modeler"
  exporterVersion="5.x">

  <!-- ═══════════════════════════════════════════════════════════════
       DMF Platform Bootstrap Process
       Canonical BPMN 2.0 model of fresh cluster bring-up.
       ISO/IEC 19510-compliant.
       Source: docs/processes/diagrams/dmf-bootstrap.bpmn
       See: docs/processes/dmf-bootstrap.md
  ════════════════════════════════════════════════════════════════ -->

  <!-- ── Operator pool ──────────────────────────────────────────── -->
  <bpmn:collaboration id="Collab_DMFBootstrap">
    <bpmn:participant id="Pool_Operator" name="Operator" processRef="Process_Operator" />
    <bpmn:participant id="Pool_Terraform" name="Terraform / dmf-env" processRef="Process_Terraform" />
    <bpmn:participant id="Pool_Ansible" name="Ansible / dmf-infra" processRef="Process_Ansible" />
    <bpmn:participant id="Pool_OpenBao" name="OpenBao" processRef="Process_OpenBao" />
    <bpmn:participant id="Pool_DMFCMS" name="dmf-cms" processRef="Process_DMFCMS" />

    <!-- Message flows: Operator → Terraform -->
    <bpmn:messageFlow id="MF_TriggerTF" sourceRef="Task_RunTerraform" targetRef="Task_ProvisionInfra" />
    <!-- Message flows: Operator → Ansible pre-seed -->
    <bpmn:messageFlow id="MF_TriggerPreSeed" sourceRef="Task_RunPreSeed" targetRef="Task_PreSeedProvision" />
    <!-- Message flows: Operator seeds bundle into OpenBao -->
    <bpmn:messageFlow id="MF_SeedBao" sourceRef="Task_SeedBundle" targetRef="Task_ReceiveSeed" />
    <!-- Message flows: Operator → Ansible post-seed -->
    <bpmn:messageFlow id="MF_TriggerPostSeed" sourceRef="Task_RunPostSeed" targetRef="Task_PostSeedProvision" />
    <!-- Message flows: Operator → Ansible configure -->
    <bpmn:messageFlow id="MF_TriggerConfigure" sourceRef="Task_RunConfigure" targetRef="Task_ConfigureApps" />
    <!-- Message flows: Operator → Ansible verify -->
    <bpmn:messageFlow id="MF_TriggerVerify" sourceRef="Task_RunVerify" targetRef="Task_VerifyBootstrap" />
    <!-- Message flows: dmf-cms reachable signal back to Operator -->
    <bpmn:messageFlow id="MF_CMSReady" sourceRef="Task_ExposeCMS" targetRef="Catch_CMSReachable" />
  </bpmn:collaboration>

  <!-- ═══════════════════════════════════════════════════════════════
       OPERATOR PROCESS
  ════════════════════════════════════════════════════════════════ -->
  <bpmn:process id="Process_Operator" name="Operator" isExecutable="false">

    <bpmn:startEvent id="Start_Operator" name="Cloud credentials and empty target environment available">
      <bpmn:outgoing>Flow_Op01</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- Phase 0: Initialise pre-Bao bootstrap bundle -->
    <bpmn:userTask id="Task_InitBundle" name="Initialise pre-Bao bootstrap bundle">
      <bpmn:documentation>
        Operator runs: dmf-env/bin/bootstrap-secrets.sh init &lt;env&gt;
        Collects provider tokens, generates k3s token and shared bootstrap admin identity.
        Encrypts bundle to ${DMF_BOOTSTRAP_BUNDLE_DIR}/&lt;env&gt;.sops.yaml outside any git tree.
      </bpmn:documentation>
      <bpmn:incoming>Flow_Op01</bpmn:incoming>
      <bpmn:outgoing>Flow_Op02</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_DoctorBundle" name="Validate bootstrap bundle with doctor check">
      <bpmn:documentation>
        Operator runs: dmf-env/bin/bootstrap-secrets.sh doctor &lt;env&gt;
        Verifies all required secrets are present and the age key can decrypt the bundle.
        Fails fast before touching the cluster.
      </bpmn:documentation>
      <bpmn:incoming>Flow_Op02</bpmn:incoming>
      <bpmn:outgoing>Flow_Op03</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_BundleValid" name="Bundle valid?">
      <bpmn:incoming>Flow_Op03</bpmn:incoming>
      <bpmn:outgoing>Flow_Op04_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_Op04_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="End_BundleInvalid" name="Bootstrap aborted — bundle invalid">
      <bpmn:documentation>Operator must fix the bundle and restart from the init step.</bpmn:documentation>
      <bpmn:incoming>Flow_Op04_No</bpmn:incoming>
      <bpmn:terminateEventDefinition />
    </bpmn:endEvent>

    <!-- Phase 1: Provision cloud infrastructure via Terraform -->
    <bpmn:userTask id="Task_RunTerraform" name="Apply Terraform Layer-1 infrastructure">
      <bpmn:documentation>
        Operator runs: dmf-env/bin/tf-apply.sh &lt;env&gt;
        Provisions Hetzner VMs, cloud-init with k3s-admin pubkey and AWX control-node pubkey.
        Outputs: node IPs, load-balancer IP.
      </bpmn:documentation>
      <bpmn:incoming>Flow_Op04_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_Op05</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_TFApplied" name="Terraform apply successful?">
      <bpmn:incoming>Flow_Op05</bpmn:incoming>
      <bpmn:outgoing>Flow_Op06_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_Op06_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="End_TFFailed" name="Bootstrap aborted — infrastructure provisioning failed">
      <bpmn:incoming>Flow_Op06_No</bpmn:incoming>
      <bpmn:terminateEventDefinition />
    </bpmn:endEvent>

    <!-- Phase 2: Pre-seed Ansible provision -->
    <bpmn:userTask id="Task_RunPreSeed" name="Run pre-seed provision playbook">
      <bpmn:documentation>
        Operator runs: dmf-env/bin/run-playbook.sh &lt;env&gt; bootstrap-provision-pre-seed.yml
        Installs: host platform, k3s cluster, ingress, cert-manager, Tailscale, Longhorn,
        Zot (htpasswd only), OpenBao, ESO, network policies.
        Must complete before seed-bao.
      </bpmn:documentation>
      <bpmn:incoming>Flow_Op06_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_Op07</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_PreSeedOK" name="Pre-seed provision succeeded?">
      <bpmn:incoming>Flow_Op07</bpmn:incoming>
      <bpmn:outgoing>Flow_Op08_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_Op08_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="End_PreSeedFailed" name="Bootstrap aborted — pre-seed provision failed">
      <bpmn:incoming>Flow_Op08_No</bpmn:incoming>
      <bpmn:terminateEventDefinition />
    </bpmn:endEvent>

    <!-- Phase 3: Manual OpenBao init and unseal -->
    <bpmn:userTask id="Task_InitOpenBao" name="Initialise and unseal OpenBao">
      <bpmn:documentation>
        Operator runs: bao operator init (via SSH to control node).
        Distributes 5 Shamir shares per ADR-0009.
        Runs dmf-env/bin/unseal-openbao.sh to unseal with shares 1+2+3.
        Policy bootstrap is performed by the openbao Ansible role during pre-seed.
      </bpmn:documentation>
      <bpmn:incoming>Flow_Op08_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_Op09</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_BaoUnsealed" name="OpenBao unsealed?">
      <bpmn:incoming>Flow_Op09</bpmn:incoming>
      <bpmn:outgoing>Flow_Op10_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_Op10_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="End_UnsealFailed" name="Bootstrap blocked — unseal quorum not achieved">
      <bpmn:documentation>
        Operator must locate a sufficient quorum of Shamir shares (3 of 5) and retry.
        See dmf-openbao-unseal skill and ADR-0009.
      </bpmn:documentation>
      <bpmn:incoming>Flow_Op10_No</bpmn:incoming>
      <bpmn:terminateEventDefinition />
    </bpmn:endEvent>

    <!-- Phase 4: Seed bootstrap bundle into OpenBao -->
    <bpmn:userTask id="Task_SeedBundle" name="Seed bootstrap bundle into OpenBao">
      <bpmn:documentation>
        Operator runs: dmf-env/bin/bootstrap-secrets.sh seed-bao &lt;env&gt;
        Decrypts bundle, writes platform bootstrap paths to OpenBao via SSH to control node.
        Collision policy: missing → write; same value → no-op; differing platform path → fail.
        Must complete before post-seed provision.
      </bpmn:documentation>
      <bpmn:incoming>Flow_Op10_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_Op11</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_SeedOK" name="Bundle seeded without collision?">
      <bpmn:incoming>Flow_Op11</bpmn:incoming>
      <bpmn:outgoing>Flow_Op12_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_Op12_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="End_SeedCollision" name="Bootstrap blocked — seed collision detected">
      <bpmn:documentation>
        A differing value exists in OpenBao for a platform path.
        Operator must run explicit rotate operation or resolve the conflict manually.
      </bpmn:documentation>
      <bpmn:incoming>Flow_Op12_No</bpmn:incoming>
      <bpmn:terminateEventDefinition />
    </bpmn:endEvent>

    <!-- Phase 5: Post-seed Ansible provision -->
    <bpmn:userTask id="Task_RunPostSeed" name="Run post-seed provision playbook">
      <bpmn:documentation>
        Operator runs: dmf-env/bin/run-playbook.sh &lt;env&gt; bootstrap-provision-post-seed.yml
        Installs: Prometheus, Loki, Promtail, Grafana, Authentik, NetBox, Forgejo, AWX,
        DMF Console — all in vanilla/local form.
        Playbook asserts secret/platform/bootstrap_admin and secret/platform/k3s/cluster exist first.
      </bpmn:documentation>
      <bpmn:incoming>Flow_Op12_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_Op13</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_PostSeedOK" name="Post-seed provision succeeded?">
      <bpmn:incoming>Flow_Op13</bpmn:incoming>
      <bpmn:outgoing>Flow_Op14_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_Op14_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="End_PostSeedFailed" name="Bootstrap aborted — post-seed provision failed">
      <bpmn:incoming>Flow_Op14_No</bpmn:incoming>
      <bpmn:terminateEventDefinition />
    </bpmn:endEvent>

    <!-- Phase 6: Bootstrap Configure -->
    <bpmn:userTask id="Task_RunConfigure" name="Run bootstrap configure playbook">
      <bpmn:documentation>
        Operator runs: dmf-env/bin/run-playbook.sh &lt;env&gt; bootstrap-configure.yml
        Wires: Authentik OIDC graph, app identity overlays, NetBox SoT, Forgejo repos,
        AWX integration, born-inventory, CMS API tokens.
        Does not launch media workloads.
      </bpmn:documentation>
      <bpmn:incoming>Flow_Op14_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_Op15</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_ConfigureOK" name="Configure succeeded?">
      <bpmn:incoming>Flow_Op15</bpmn:incoming>
      <bpmn:outgoing>Flow_Op16_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_Op16_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="End_ConfigureFailed" name="Bootstrap aborted — configure failed">
      <bpmn:incoming>Flow_Op16_No</bpmn:incoming>
      <bpmn:terminateEventDefinition />
    </bpmn:endEvent>

    <!-- Phase 7: Bootstrap Verify -->
    <bpmn:userTask id="Task_RunVerify" name="Run bootstrap verify playbook">
      <bpmn:documentation>
        Operator runs: dmf-env/bin/run-playbook.sh &lt;env&gt; bootstrap-verify.yml
        Checks: k3s nodes Ready, CoreDNS, ingress reachability, cert-manager, Longhorn,
        OpenBao unsealed, ESO ClusterSecretStore Ready, Authentik break-glass,
        monitoring stack deployed, OIDC operator identity has admin access.
      </bpmn:documentation>
      <bpmn:incoming>Flow_Op16_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_Op17</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_VerifyOK" name="All verification gates pass?">
      <bpmn:incoming>Flow_Op17</bpmn:incoming>
      <bpmn:outgoing>Flow_Op18_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_Op18_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="End_VerifyFailed" name="Bootstrap incomplete — verification gate failed">
      <bpmn:incoming>Flow_Op18_No</bpmn:incoming>
      <bpmn:terminateEventDefinition />
    </bpmn:endEvent>

    <!-- Wait for dmf-cms reachable signal -->
    <bpmn:intermediateCatchEvent id="Catch_CMSReachable" name="dmf-cms reachable">
      <bpmn:incoming>Flow_Op18_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_Op19</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_CMSReady" messageRef="Msg_CMSReady" />
    </bpmn:intermediateCatchEvent>

    <bpmn:endEvent id="End_BootstrapComplete" name="Cluster healthy, OpenBao unsealed, dmf-cms reachable">
      <bpmn:incoming>Flow_Op19</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Sequence flows: Operator -->
    <bpmn:sequenceFlow id="Flow_Op01" sourceRef="Start_Operator" targetRef="Task_InitBundle" />
    <bpmn:sequenceFlow id="Flow_Op02" sourceRef="Task_InitBundle" targetRef="Task_DoctorBundle" />
    <bpmn:sequenceFlow id="Flow_Op03" sourceRef="Task_DoctorBundle" targetRef="GW_BundleValid" />
    <bpmn:sequenceFlow id="Flow_Op04_Yes" name="Yes" sourceRef="GW_BundleValid" targetRef="Task_RunTerraform" />
    <bpmn:sequenceFlow id="Flow_Op04_No" name="No" sourceRef="GW_BundleValid" targetRef="End_BundleInvalid" />
    <bpmn:sequenceFlow id="Flow_Op05" sourceRef="Task_RunTerraform" targetRef="GW_TFApplied" />
    <bpmn:sequenceFlow id="Flow_Op06_Yes" name="Yes" sourceRef="GW_TFApplied" targetRef="Task_RunPreSeed" />
    <bpmn:sequenceFlow id="Flow_Op06_No" name="No" sourceRef="GW_TFApplied" targetRef="End_TFFailed" />
    <bpmn:sequenceFlow id="Flow_Op07" sourceRef="Task_RunPreSeed" targetRef="GW_PreSeedOK" />
    <bpmn:sequenceFlow id="Flow_Op08_Yes" name="Yes" sourceRef="GW_PreSeedOK" targetRef="Task_InitOpenBao" />
    <bpmn:sequenceFlow id="Flow_Op08_No" name="No" sourceRef="GW_PreSeedOK" targetRef="End_PreSeedFailed" />
    <bpmn:sequenceFlow id="Flow_Op09" sourceRef="Task_InitOpenBao" targetRef="GW_BaoUnsealed" />
    <bpmn:sequenceFlow id="Flow_Op10_Yes" name="Yes" sourceRef="GW_BaoUnsealed" targetRef="Task_SeedBundle" />
    <bpmn:sequenceFlow id="Flow_Op10_No" name="No" sourceRef="GW_BaoUnsealed" targetRef="End_UnsealFailed" />
    <bpmn:sequenceFlow id="Flow_Op11" sourceRef="Task_SeedBundle" targetRef="GW_SeedOK" />
    <bpmn:sequenceFlow id="Flow_Op12_Yes" name="Yes" sourceRef="GW_SeedOK" targetRef="Task_RunPostSeed" />
    <bpmn:sequenceFlow id="Flow_Op12_No" name="No" sourceRef="GW_SeedOK" targetRef="End_SeedCollision" />
    <bpmn:sequenceFlow id="Flow_Op13" sourceRef="Task_RunPostSeed" targetRef="GW_PostSeedOK" />
    <bpmn:sequenceFlow id="Flow_Op14_Yes" name="Yes" sourceRef="GW_PostSeedOK" targetRef="Task_RunConfigure" />
    <bpmn:sequenceFlow id="Flow_Op14_No" name="No" sourceRef="GW_PostSeedOK" targetRef="End_PostSeedFailed" />
    <bpmn:sequenceFlow id="Flow_Op15" sourceRef="Task_RunConfigure" targetRef="GW_ConfigureOK" />
    <bpmn:sequenceFlow id="Flow_Op16_Yes" name="Yes" sourceRef="GW_ConfigureOK" targetRef="Task_RunVerify" />
    <bpmn:sequenceFlow id="Flow_Op16_No" name="No" sourceRef="GW_ConfigureOK" targetRef="End_ConfigureFailed" />
    <bpmn:sequenceFlow id="Flow_Op17" sourceRef="Task_RunVerify" targetRef="GW_VerifyOK" />
    <bpmn:sequenceFlow id="Flow_Op18_Yes" name="Yes" sourceRef="GW_VerifyOK" targetRef="Catch_CMSReachable" />
    <bpmn:sequenceFlow id="Flow_Op18_No" name="No" sourceRef="GW_VerifyOK" targetRef="End_VerifyFailed" />
    <bpmn:sequenceFlow id="Flow_Op19" sourceRef="Catch_CMSReachable" targetRef="End_BootstrapComplete" />
  </bpmn:process>

  <!-- ═══════════════════════════════════════════════════════════════
       TERRAFORM / dmf-env PROCESS
  ════════════════════════════════════════════════════════════════ -->
  <bpmn:process id="Process_Terraform" name="Terraform / dmf-env" isExecutable="false">

    <bpmn:startEvent id="Start_TF" name="Terraform apply triggered">
      <bpmn:outgoing>Flow_TF01</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_TFStart" messageRef="Msg_TriggerTF" />
    </bpmn:startEvent>

    <bpmn:serviceTask id="Task_ProvisionInfra" name="Provision cloud VMs and network">
      <bpmn:documentation>
        Hetzner CAX21 ARM64 nodes provisioned via OpenTofu.
        cloud-init injects: k3s-admin pubkey and AWX control-node pubkey (ADR-0016).
        Outputs: control node IP, worker node IPs, load-balancer IP.
      </bpmn:documentation>
      <bpmn:incoming>Flow_TF01</bpmn:incoming>
      <bpmn:outgoing>Flow_TF02</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="End_TF" name="Infrastructure provisioned">
      <bpmn:incoming>Flow_TF02</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_TF01" sourceRef="Start_TF" targetRef="Task_ProvisionInfra" />
    <bpmn:sequenceFlow id="Flow_TF02" sourceRef="Task_ProvisionInfra" targetRef="End_TF" />
  </bpmn:process>

  <!-- ═══════════════════════════════════════════════════════════════
       ANSIBLE / dmf-infra PROCESS
  ════════════════════════════════════════════════════════════════ -->
  <bpmn:process id="Process_Ansible" name="Ansible / dmf-infra" isExecutable="false">

    <!-- Pre-seed provision -->
    <bpmn:startEvent id="Start_Ansible_PreSeed" name="Pre-seed provision triggered">
      <bpmn:outgoing>Flow_AN01</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_ANPreSeed" messageRef="Msg_TriggerPreSeed" />
    </bpmn:startEvent>

    <bpmn:serviceTask id="Task_PreSeedProvision" name="Execute pre-seed provision">
      <bpmn:documentation>
        bootstrap-provision-pre-seed.yml via run-playbook.sh.
        Phases: host platform (baseline + harden) → k3s cluster → ingress (public + private)
        → cert-manager → Tailscale → Longhorn → Zot (htpasswd only)
        → OpenBao install + init → ESO + ClusterSecretStore → network policies.
        No Layer 6 app install. No app-admin-facts calls.
      </bpmn:documentation>
      <bpmn:incoming>Flow_AN01</bpmn:incoming>
      <bpmn:outgoing>Flow_AN02</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Post-seed provision -->
    <bpmn:intermediateCatchEvent id="Catch_PostSeedTrigger" name="Post-seed provision triggered">
      <bpmn:incoming>Flow_AN02</bpmn:incoming>
      <bpmn:outgoing>Flow_AN03</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_ANPostSeed" messageRef="Msg_TriggerPostSeed" />
    </bpmn:intermediateCatchEvent>

    <bpmn:serviceTask id="Task_AssertSecretsExist" name="Assert platform secrets exist in OpenBao">
      <bpmn:documentation>
        Asserts secret/platform/bootstrap_admin and secret/platform/k3s/cluster exist.
        Fails the playbook if absent — prevents accidental first-run use of lifecycle-provision.yml.
      </bpmn:documentation>
      <bpmn:incoming>Flow_AN03</bpmn:incoming>
      <bpmn:outgoing>Flow_AN04</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Task_PostSeedProvision" name="Install Layer 6 applications in vanilla form">
      <bpmn:documentation>
        bootstrap-provision-post-seed.yml via run-playbook.sh.
        Installs: Prometheus, Loki, Promtail, Grafana, Authentik, NetBox, Forgejo, AWX, DMF Console.
        All apps receive shared bootstrap admin identity from OpenBao.
        No cross-app wiring.
      </bpmn:documentation>
      <bpmn:incoming>Flow_AN04</bpmn:incoming>
      <bpmn:outgoing>Flow_AN05</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Bootstrap Configure -->
    <bpmn:intermediateCatchEvent id="Catch_ConfigureTrigger" name="Configure triggered">
      <bpmn:incoming>Flow_AN05</bpmn:incoming>
      <bpmn:outgoing>Flow_AN06</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_ANConfigure" messageRef="Msg_TriggerConfigure" />
    </bpmn:intermediateCatchEvent>

    <bpmn:serviceTask id="Task_ConfigureApps" name="Wire cross-app relationships">
      <bpmn:documentation>
        bootstrap-configure.yml via run-playbook.sh.
        Configures: Authentik OIDC graph, app identity overlays (Zot, Grafana, NetBox,
        Forgejo, AWX, DMF Console), NetBox SoT, Forgejo service repos, AWX SCM projects
        and job templates, born-inventory registration, CMS API tokens.
        Does not launch media workloads.
      </bpmn:documentation>
      <bpmn:incoming>Flow_AN06</bpmn:incoming>
      <bpmn:outgoing>Flow_AN07</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Bootstrap Verify -->
    <bpmn:intermediateCatchEvent id="Catch_VerifyTrigger" name="Verify triggered">
      <bpmn:incoming>Flow_AN07</bpmn:incoming>
      <bpmn:outgoing>Flow_AN08</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_ANVerify" messageRef="Msg_TriggerVerify" />
    </bpmn:intermediateCatchEvent>

    <bpmn:serviceTask id="Task_VerifyBootstrap" name="Execute bootstrap verification gates">
      <bpmn:documentation>
        bootstrap-verify.yml via run-playbook.sh.
        Gates: k3s nodes Ready, CoreDNS, ingress, cert-manager, Longhorn, Zot auth,
        OpenBao unsealed and reachable, ESO ClusterSecretStore Ready,
        Authentik break-glass login, monitoring stack, OIDC admin identity.
      </bpmn:documentation>
      <bpmn:incoming>Flow_AN08</bpmn:incoming>
      <bpmn:outgoing>Flow_AN09</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="End_Ansible" name="Bootstrap playbooks complete">
      <bpmn:incoming>Flow_AN09</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_AN01" sourceRef="Start_Ansible_PreSeed" targetRef="Task_PreSeedProvision" />
    <bpmn:sequenceFlow id="Flow_AN02" sourceRef="Task_PreSeedProvision" targetRef="Catch_PostSeedTrigger" />
    <bpmn:sequenceFlow id="Flow_AN03" sourceRef="Catch_PostSeedTrigger" targetRef="Task_AssertSecretsExist" />
    <bpmn:sequenceFlow id="Flow_AN04" sourceRef="Task_AssertSecretsExist" targetRef="Task_PostSeedProvision" />
    <bpmn:sequenceFlow id="Flow_AN05" sourceRef="Task_PostSeedProvision" targetRef="Catch_ConfigureTrigger" />
    <bpmn:sequenceFlow id="Flow_AN06" sourceRef="Catch_ConfigureTrigger" targetRef="Task_ConfigureApps" />
    <bpmn:sequenceFlow id="Flow_AN07" sourceRef="Task_ConfigureApps" targetRef="Catch_VerifyTrigger" />
    <bpmn:sequenceFlow id="Flow_AN08" sourceRef="Catch_VerifyTrigger" targetRef="Task_VerifyBootstrap" />
    <bpmn:sequenceFlow id="Flow_AN09" sourceRef="Task_VerifyBootstrap" targetRef="End_Ansible" />
  </bpmn:process>

  <!-- ═══════════════════════════════════════════════════════════════
       OPENBAO PROCESS
  ════════════════════════════════════════════════════════════════ -->
  <bpmn:process id="Process_OpenBao" name="OpenBao" isExecutable="false">

    <bpmn:startEvent id="Start_Bao" name="Seed bundle received">
      <bpmn:outgoing>Flow_Bao01</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_BaoSeed" messageRef="Msg_SeedBao" />
    </bpmn:startEvent>

    <bpmn:serviceTask id="Task_ReceiveSeed" name="Write platform secrets to KV store">
      <bpmn:documentation>
        Receives seed via stdin transport through SSH to control node (ADR-0007 compliant).
        Writes: secret/platform/bootstrap_admin, secret/platform/k3s/cluster,
        provider paths (hetzner, cloudflare, tailscale, notifications),
        app-local admin compatibility copies (same value as bootstrap_admin).
        Collision policy enforced by bootstrap-secrets.sh.
      </bpmn:documentation>
      <bpmn:incoming>Flow_Bao01</bpmn:incoming>
      <bpmn:outgoing>Flow_Bao02</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="End_Bao" name="OpenBao seeded">
      <bpmn:incoming>Flow_Bao02</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Bao01" sourceRef="Start_Bao" targetRef="Task_ReceiveSeed" />
    <bpmn:sequenceFlow id="Flow_Bao02" sourceRef="Task_ReceiveSeed" targetRef="End_Bao" />
  </bpmn:process>

  <!-- ═══════════════════════════════════════════════════════════════
       DMF-CMS PROCESS
  ════════════════════════════════════════════════════════════════ -->
  <bpmn:process id="Process_DMFCMS" name="dmf-cms" isExecutable="false">

    <bpmn:startEvent id="Start_CMS" name="AWX integration and CMS API tokens wired">
      <bpmn:outgoing>Flow_CMS01</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="Task_ExposeCMS" name="Expose dmf-cms via ingress">
      <bpmn:documentation>
        dmf-cms deployment is ready and reachable through the configured ingress hostname.
        Authentik OIDC provider for dmf-cms is wired during bootstrap-configure.
      </bpmn:documentation>
      <bpmn:incoming>Flow_CMS01</bpmn:incoming>
      <bpmn:outgoing>Flow_CMS02</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="End_CMS" name="dmf-cms reachable and OIDC-authenticated">
      <bpmn:incoming>Flow_CMS02</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_CMS01" sourceRef="Start_CMS" targetRef="Task_ExposeCMS" />
    <bpmn:sequenceFlow id="Flow_CMS02" sourceRef="Task_ExposeCMS" targetRef="End_CMS" />
  </bpmn:process>

  <!-- ═══════════════════════════════════════════════════════════════
       MESSAGES
  ════════════════════════════════════════════════════════════════ -->
  <bpmn:message id="Msg_TriggerTF" name="TriggerTerraformApply" />
  <bpmn:message id="Msg_TriggerPreSeed" name="TriggerPreSeedProvision" />
  <bpmn:message id="Msg_SeedBao" name="SeedBootstrapBundle" />
  <bpmn:message id="Msg_TriggerPostSeed" name="TriggerPostSeedProvision" />
  <bpmn:message id="Msg_TriggerConfigure" name="TriggerBootstrapConfigure" />
  <bpmn:message id="Msg_TriggerVerify" name="TriggerBootstrapVerify" />
  <bpmn:message id="Msg_CMSReady" name="CMSReachable" />

  <!-- ═══════════════════════════════════════════════════════════════
       BPMN DI — Diagram Interchange
       Left-to-right layout. Pools stacked vertically.
       Operator pool: y=20, height=820 (tallest — drives all phases)
       Terraform pool: y=860, height=120
       Ansible pool: y=1000, height=170
       OpenBao pool: y=1190, height=120
       dmf-cms pool: y=1330, height=120
  ════════════════════════════════════════════════════════════════ -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collab_DMFBootstrap">

