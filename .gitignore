# Legacy safety net: component repos are siblings of the umbrella since the
# public release (2026-06-11, ADR-0001 amendment) — nothing is nested anymore.
# These entries only protect old nested clones from accidentally staging a
# component repo. The umbrella tracks docs + meta only.
/dmf-cms/
/dmf-runbooks/
/dmf-central/
/dmf-infra/
/dmf-env/
/dmf-media/
/dmf-init/
/dmf-promsd/

# Upstream evaluation clone — EBU/NABA Media eXchange Layer SDK.
# Cloned 2026-05-17 for media-node spike; not a component repo (yet).
/mxl/

# macOS metadata
.DS_Store
.DS_Store?
._*
.AppleDouble
.LSOverride
Icon
Icon?
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk
__MACOSX/

# Editor / local workspace noise
.idea/
.vscode/
*.swp
*.swo
*~

# Local-only scratch
/scratch/

# Local live repo-state snapshot generated from committed STATUS.md notes.
/STATUS.local.md

# Qwen artifacts
.qwen/*.orig

# Agentic harness in-flight task state (runtime; promote to loop-log.md on completion)
# Harness mothballed 2026-06-04; stale runtime artifacts cleared into archive/.
# Both stay gitignored — they carry PIDs / /tmp paths / stale run state, never committed.
/docs/agentic/in-flight/*.json
/docs/agentic/in-flight/archive/*.json

# === Secrets-prevention baseline (DMF Platform 2026-05-07) ===
# Patterns that should never be committed across any DMF Platform repo.
# Repo-specific rules belong above this block; add new shared rules here.

# Kubeconfigs
*.kubeconfig
kubeconfig
kube.config

# Terraform / OpenTofu state
*.tfstate
*.tfstate.*
.terraform/

# Ansible inventory (auto-generated)
hosts.ini

# Cryptographic material
*.pem
*.key
*.p12
*.pfx

# OpenBao / Vault tokens + key shares
openbao-keys*.json
openbao-keys*.hcl
.bao-token
.vault-token

# Ansible secrets
*.retry
.vault_pass
vault_pass

# Env files / generic secrets
.env
.env.*
.netrc
secret_id
secret_id.*
.claude/scheduled_tasks.lock

# Per-agent skill views are GENERATED from .agents/skills/ by bin/sync-skills.sh
# and must never be tracked (ADR-0042, umbrella issue #46). Capture scratch and
# operator-private canonical skills are likewise local-only.
.claude/skills/
.qwen/skills/
.agents/skills/_inbox/
# qwen runtime aid embedding scrub-detection patterns — never track (WP16)
.agents/skills/identity-scrub-sweep/

# Operator-private gitleaks rules (identity/topology) — never track
.gitleaks.local.toml
