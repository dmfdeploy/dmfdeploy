#!/usr/bin/env bash
# .githooks/pre-commit — local pre-commit gates for the umbrella.
#
# Runs staged secret scans, refreshes deterministic generated docs, and checks
# documentation/frontmatter consistency before allowing the commit.
#
# Activate once per clone:
#   git config core.hooksPath .githooks
#   (or: bin/install-hooks.sh)
#
# Escape hatches:
#   STATUS_HOOK_SKIP=1 git commit ...    # skip umbrella doc refresh/check steps
#   git commit --no-verify ...           # bypass all hooks (use sparingly)

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

# ── Secret scanning (R1 §6 switchover: THIN CALLER of the shared library).
# The umbrella (and any repo carrying bin/dmf-scan) scans staged changes via
# the one implementation — manifest-driven grep pass + pinned gitleaks with
# the ephemeral merged config — under the HARDCODED pre-commit context.
# FAIL-CLOSED (§5.3): a missing private manifest refuses the commit; there is
# no public-only escape here (§5.4). Operators/agents: the private manifest
# lives at ~/.dmfdeploy/pattern-manifest.private.toml (see
# bin/migrate-private-manifest.py). This gate sits ABOVE the STATUS_HOOK_SKIP
# hatch — that hatch never skips secret scanning.
if [ -x "$REPO_ROOT/bin/dmf-scan" ]; then
    if ! "$REPO_ROOT/bin/dmf-scan" staged --repo "$REPO_ROOT" --context pre-commit; then
        echo "" >&2
        echo "[pre-commit] dmf-scan: staged changes refused (see class line above)" >&2
        echo "  LEAK_FOUND:    remove the value (true FP: adjust the manifest via review)" >&2
        echo "  CONFIG_ERROR:  fix the environment — never edit patterns to pass" >&2
        echo "  bypass (rare): git commit --no-verify" >&2
        exit 1
    fi
    # Generated-view drift (public region literal, private view redacted).
    if ! "$REPO_ROOT/bin/dmf-scan" check >/dev/null 2>&1; then
        echo "" >&2
        echo "[pre-commit] generated gitleaks views drifted from the manifests — refusing commit" >&2
        "$REPO_ROOT/bin/dmf-scan" check 2>&1 | sed 's/^/  /' >&2
        echo "  public: bin/gen-gitleaks-rules.py --emit (stage .gitleaks.toml)" >&2
        echo "  private: regenerate locally (bin/migrate-private-manifest.py --force --rewrite-legacy)" >&2
        exit 1
    fi
# Legacy fallback for component repos that share this hooksPath but do not
# carry the scan library yet (they keep the old two-pass gitleaks behavior
# until the #73 cross-repo distribution lands).
elif command -v gitleaks >/dev/null 2>&1; then
    if ! gitleaks protect --staged --no-banner --redact >/dev/null 2>&1; then
        echo "" >&2
        echo "[pre-commit] gitleaks: leak detected in staged changes — refusing commit" >&2
        echo "  inspect:        gitleaks protect --staged -v" >&2
        exit 1
    fi
    if [ -f "$REPO_ROOT/.gitleaks.local.toml" ]; then
        if ! gitleaks protect --staged --no-banner --redact \
                --config "$REPO_ROOT/.gitleaks.local.toml" >/dev/null 2>&1; then
            echo "" >&2
            echo "[pre-commit] gitleaks (operator-private rules): identity/topology literal in staged changes — refusing commit" >&2
            exit 1
        fi
    fi
elif [ "${GITLEAKS_HOOK_QUIET:-0}" != "1" ]; then
    echo "[pre-commit] WARN: gitleaks not installed — skipping secret scan." >&2
    echo "             brew install gitleaks (silence with GITLEAKS_HOOK_QUIET=1)" >&2
fi

# Only fire the umbrella-specific bits when umbrella scripts exist. Component
# repos use the same hooksPath only if their operators opt in; we don't want to
# break them silently if they happen to share a config.
[ -x "$REPO_ROOT/bin/check-docs.sh" ] || exit 0

# Skip during rebase / merge / cherry-pick — generated-doc noise from the hook
# just confuses the operator there.
[ -d "$REPO_ROOT/.git/rebase-merge" ] && exit 0
[ -d "$REPO_ROOT/.git/rebase-apply" ] && exit 0
[ -f "$REPO_ROOT/.git/MERGE_HEAD" ] && exit 0
[ -f "$REPO_ROOT/.git/CHERRY_PICK_HEAD" ] && exit 0

[ "${STATUS_HOOK_SKIP:-0}" = "1" ] && {
    echo "[pre-commit] STATUS_HOOK_SKIP=1 — skipping umbrella doc refresh/check steps"
    exit 0
}

# Refresh the scripts catalog if a script header may have changed
if [ -x "$REPO_ROOT/bin/generate-scripts-catalog.sh" ]; then
    "$REPO_ROOT/bin/generate-scripts-catalog.sh" >/dev/null
    if ! git diff --quiet -- docs/SCRIPTS.md 2>/dev/null; then
        git add docs/SCRIPTS.md
        echo "[pre-commit] docs/SCRIPTS.md auto-refreshed and staged"
    fi
fi

# Regenerate the plans index and run the doc gate
if [ -x "$REPO_ROOT/bin/generate-plans-index.sh" ]; then
    "$REPO_ROOT/bin/generate-plans-index.sh" >/dev/null
    if ! git diff --quiet -- docs/plans/INDEX.md 2>/dev/null; then
        git add docs/plans/INDEX.md
        echo "[pre-commit] docs/plans/INDEX.md auto-refreshed and staged"
    fi
fi

if [ -x "$REPO_ROOT/bin/check-docs.sh" ]; then
    if ! "$REPO_ROOT/bin/check-docs.sh" >/dev/null 2>&1; then
        echo "" >&2
        echo "[pre-commit] check-docs: doc gate failed — refusing commit" >&2
        "$REPO_ROOT/bin/check-docs.sh" 2>&1 | sed 's/^/  /' >&2
        echo "  fix frontmatter or STATUS_HOOK_SKIP=1 to bypass" >&2
        exit 1
    fi
fi

# Working-model block sync (umbrella issue #32): copies of the agent-context
# block must match docs/templates/working-model-block.md byte-for-byte.
if [ -x "$REPO_ROOT/bin/check-working-model-sync.sh" ]; then
    if ! "$REPO_ROOT/bin/check-working-model-sync.sh" --umbrella-only >/dev/null 2>&1; then
        echo "" >&2
        echo "[pre-commit] working-model block drifted — refusing commit" >&2
        "$REPO_ROOT/bin/check-working-model-sync.sh" --umbrella-only 2>&1 | sed 's/^/  /' >&2
        echo "  edit docs/templates/working-model-block.md, then re-paste copies" >&2
        exit 1
    fi
fi

# Skills sync (ADR-0042): per-agent .claude/.qwen skill views are generated from
# .agents/skills/ and must stay gitignored — nothing generated or un-promoted
# (the _inbox) may be committed.
if [ -x "$REPO_ROOT/bin/sync-skills.sh" ]; then
    if ! "$REPO_ROOT/bin/sync-skills.sh" --check --umbrella-only >/dev/null 2>&1; then
        echo "" >&2
        echo "[pre-commit] skills out of sync with canonical — refusing commit" >&2
        "$REPO_ROOT/bin/sync-skills.sh" --check --umbrella-only 2>&1 | sed 's/^/  /' >&2
        echo "  run bin/sync-skills.sh to refresh, then stage and retry" >&2
        exit 1
    fi
fi

exit 0
