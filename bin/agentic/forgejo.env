# bin/agentic/forgejo.env — sourced config for the issue-substrate scripts.
#
# Sourced by bin/agentic/issue-{open,list,promote,close,migrate-to-github}.sh.
# Real values live in dmf-env (the private environment-specific sibling
# repo), not here. This file provides placeholder defaults + the loader
# that brings the dmf-env values in.
#
# CONVENTIONS:
#   - This file uses placeholder syntax everywhere (Constitution Rule 8).
#     Real host, owner, and token path live in dmf-env, never here.
#   - The token itself is NEVER stored in dmf-env either — only a PATH to a
#     token file the operator manages on their workstation (analogous to
#     ~/.config/backblaze/b2.txt).
#   - The scripts fail loud + early if any variable is unset or still bears
#     a placeholder value at runtime (forgejo_validate_config below).
#
# OPERATOR SETUP (one-time per deployment of the platform):
#
#   1. Create a dedicated Forgejo service user `agentic-svc` (Constitution
#      Rule 11: workers never call this script directly; the user identity
#      is dedicated to the orchestrator pane). Service-user naming matches
#      the existing platform convention (`forgejo-svc`, `awx-svc`, etc.;
#      see dmf-infra/CLAUDE.md §"Service account naming convention").
#
#   2. Add agentic-svc as a Collaborator on the 6 public repos
#      (dmfdeploy + 5 component repos). Permission: Issues Read+Write only.
#      Do NOT grant push, settings, or admin. dmf-env stays excluded
#      (Constitution Rule 13).
#
#   3. Mint a PAT FOR agentic-svc with scope `write:issue` ONLY (Forgejo
#      1.20+ fine-grained scopes). Older Forgejo with only the bundled
#      `repo` scope over-grants — upgrade if available, otherwise accept
#      the broader surface and document the deviation.
#
#   4. Save the PAT to ~/.config/forgejo/token on the workstation
#      (single line; chmod 0600). Never commit the file.
#
#   5. Create dmf-env/agentic/forgejo.env in your dmf-env clone and fill
#      in real values for FORGEJO_HOST, FORGEJO_OWNER, FORGEJO_TOKEN_PATH.
#      Use this file (the umbrella's) as the template — copy the variable
#      definitions, replace placeholders. dmf-env is private; real values
#      are safe to commit there.
#
#   6. Scripts source THIS file first (placeholder defaults), then source
#      dmf-env/agentic/forgejo.env if present — values from dmf-env win.
#
# WORST-CASE BLAST RADIUS if the PAT leaks:
#   Spam on 6 public Forgejo repos' issue trackers + ability to close/reopen
#   agent-opened issues. Cannot push code, modify settings, read source of
#   private repos, access dmf-env, or impersonate the operator. Recover by
#   revoking the PAT in Forgejo's settings and minting a new one.

# Forgejo instance hostname (no scheme, no trailing slash).
# Example: forgejo.example.com
FORGEJO_HOST="<forgejo-host>"

# Path on the operator's machine to a file containing the PAT (single line).
# Scripts cat this file; they never echo the token to stdout/argv.
FORGEJO_TOKEN_PATH="${HOME}/.config/forgejo/token"

# Org / owner under which the 6 public DMF repos live on Forgejo.
# Example: dmfdeploy
FORGEJO_OWNER="<forgejo-owner>"

# The 7 public repo names — must match the umbrella subdirectory layout.
# Kept here so the scripts iterate consistently; matches the whitelist in
# bin/sync-to-github.sh. dmf-env is DELIBERATELY ABSENT (Rule 13).
FORGEJO_PUBLIC_REPOS=(dmfdeploy dmf-cms dmf-runbooks dmf-central dmf-infra dmf-media dmf-init)

# API base URL — built from HOST at use-time. Scheme is always HTTPS.
# Scripts construct: "https://${FORGEJO_HOST}/api/v1/repos/${FORGEJO_OWNER}/${repo}/..."

# Load real values from dmf-env if present. dmf-env is the private,
# environment-specific sibling repo (see umbrella CLAUDE.md §"Component
# repos" and §"Git topology"). Setting variables AFTER the placeholder
# defaults means dmf-env wins per-variable; missing variables in dmf-env
# keep the placeholders, which forgejo_validate_config below will catch
# as still-placeholder and fail loud.
_umbrella_dir="$( cd "$( dirname "${BASH_SOURCE[0]:-$0}" )/../.." && pwd )"
if [ -f "${_umbrella_dir}/dmf-env/agentic/forgejo.env" ]; then
    # shellcheck source=/dev/null
    . "${_umbrella_dir}/dmf-env/agentic/forgejo.env"
fi
unset _umbrella_dir

# Validation — scripts call this after sourcing. Fails loud with a setup
# hint rather than producing a cryptic curl error mid-pipeline.
forgejo_validate_config() {
    local missing=()
    [ "${FORGEJO_HOST}"  = "<forgejo-host>"  ] || [ -z "${FORGEJO_HOST:-}"  ] && missing+=("FORGEJO_HOST")
    [ "${FORGEJO_OWNER}" = "<forgejo-owner>" ] || [ -z "${FORGEJO_OWNER:-}" ] && missing+=("FORGEJO_OWNER")
    [ -r "${FORGEJO_TOKEN_PATH:-}" ] || missing+=("FORGEJO_TOKEN_PATH (file unreadable)")
    if [ "${#missing[@]}" -gt 0 ]; then
        echo "forgejo.env: missing or placeholder values: ${missing[*]}" >&2
        echo "  create dmf-env/agentic/forgejo.env with real values for these variables" >&2
        echo "  see the OPERATOR SETUP section in bin/agentic/forgejo.env" >&2
        return 1
    fi
    return 0
}
